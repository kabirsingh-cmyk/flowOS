{
  "name": "flowos",
  "version": "0.1.0",
  "description": "FlowOS Reach — AI that creates, posts, and measures across every channel",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
